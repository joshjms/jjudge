# /etc/jjudge/worker.env — runtime configuration for jjudge-worker.
# Copy this file to worker.env and fill in the required values before
# starting the jjudge-worker service.
#
# Required fields are marked with *** REQUIRED ***.

# ── Lime / sandbox ────────────────────────────────────────────────────────────

# Path to the cgroup subtree delegated to the worker.
# The jjudge-cgroup.service unit creates this automatically.
LIME_CGROUP_ROOT=/sys/fs/cgroup/lime.slice/worker

# CPU set assigned to this worker instance (cpuset notation, e.g. "0-1").
# Use isolated cores that are NOT used by the OS or other services.
JUDGE_CPUS=0-1

# Directories used during judging (pre-created in the image).
JUDGE_SUBMISSIONS_DIR=/tmp/judge/submissions
JUDGE_WORK_ROOT=/tmp/judge/work
JUDGE_OVERLAYFS_DIR=/tmp/judge/overlayfs
JUDGE_ROOTFS_DIR=/rootfs

# ── Source of the rootfs tarball ──────────────────────────────────────────────
# The entrypoint skips the download if /rootfs/.installed already exists
# (which it does in this pre-built image). Leave this set so the script
# does not error out before it checks the marker file.
ROOTFS_IMG_SRC=http://localhost/unused

# ── Message queue (RabbitMQ) ─────────────────────────────────────────────────

# *** REQUIRED ***
RABBITMQ_URL=amqp://guest:guest@<rabbitmq-host>:5672/

# Queue to consume: "submissions" or "contest-submissions"
RABBITMQ_QUEUE=submissions
RABBITMQ_QUEUE_DURABLE=false
RABBITMQ_QUEUE_AUTO_DELETE=false

# ── Blob storage — choose ONE of MinIO or GCS ────────────────────────────────

# --- MinIO / S3 ---
# *** REQUIRED (or use GCS below) ***
MINIO_ENDPOINT=<minio-host>:9000
MINIO_ACCESS_KEY=<access-key>
MINIO_SECRET_KEY=<secret-key>
MINIO_BUCKET=jjudge
MINIO_USE_SSL=false

# --- Google Cloud Storage (alternative to MinIO) ---
# GCS_BUCKET=
# GCS_PROJECT_ID=
# GCS_CREDENTIALS_FILE=/etc/jjudge/gcs-credentials.json

# ── Grader service (gRPC) ─────────────────────────────────────────────────────

# *** REQUIRED ***
GRADER_ADDR=<grader-host>:50051
